# Public application URLs
FRONTEND_URL=https://app.example.com
PUBLIC_API_URL=https://api.example.com

# Sampath hosted-payment gateway. Obtain all values and exact field/signature
# details from Sampath Bank merchant onboarding; never commit real credentials.
SAMPATH_GATEWAY_URL=https://sandbox-gateway.example.com/checkout
SAMPATH_GATEWAY_METHOD=POST
SAMPATH_MERCHANT_ID=
SAMPATH_TERMINAL_ID=
SAMPATH_FIELD_TERMINAL_ID=
SAMPATH_REQUEST_HMAC_SECRET=
SAMPATH_CALLBACK_HMAC_SECRET=
SAMPATH_HMAC_ALGORITHM=sha256
SAMPATH_SIGNATURE_SEPARATOR=|

# Replace these field names/orders with Sampath's merchant integration guide.
SAMPATH_FIELD_MERCHANT_ID=merchant_id
SAMPATH_FIELD_TRANSACTION_ID=transaction_id
SAMPATH_FIELD_AMOUNT=amount
SAMPATH_FIELD_CURRENCY=currency
SAMPATH_FIELD_RETURN_URL=return_url
SAMPATH_FIELD_NOTIFY_URL=notify_url
SAMPATH_FIELD_SIGNATURE=signature
SAMPATH_FIELD_STATUS=status
SAMPATH_FIELD_REFERENCE=transaction_id
# If Sampath requires the vault-consent field in the signature, append
# savePaymentMethod here in the exact order specified by the bank.
SAMPATH_REQUEST_SIGNING_FIELDS=merchantId,transactionId,amount,currency,returnUrl,notifyUrl
SAMPATH_CALLBACK_SIGNING_FIELDS=merchantId,transactionId,amount,currency,status,reference
SAMPATH_SUCCESS_VALUES=SUCCESS,PAID,00

# Saved payment methods (optional). These fields must match Sampath's vault /
# tokenization API exactly. Audito stores only the gateway token, encrypted.
PAYMENT_TOKEN_ENCRYPTION_KEY=
SAMPATH_FIELD_SAVE_PAYMENT_METHOD=
SAMPATH_SAVE_PAYMENT_METHOD_VALUE=true
SAMPATH_CALLBACK_FIELD_PAYMENT_TOKEN=
SAMPATH_CALLBACK_FIELD_CUSTOMER_REFERENCE=
SAMPATH_CALLBACK_FIELD_CARD_BRAND=
SAMPATH_CALLBACK_FIELD_CARD_LAST4=
SAMPATH_CALLBACK_FIELD_CARD_EXPIRY_MONTH=
SAMPATH_CALLBACK_FIELD_CARD_EXPIRY_YEAR=

# Local/development testing only. This is always rejected when NODE_ENV is
# production, even if mistakenly set to true.
ENABLE_TEMPORARY_PAYMENT_ACCEPTANCE=false
